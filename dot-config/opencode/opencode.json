{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-lmstudio"
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "text-embedding-nomic-embed-text-v1_5": {
          "name": "Nomic Embed Text v1.5",
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
